{
  "buildCommand": "echo 'No build step; gateway only'",
  "installCommand": "npm ci",
  "framework": null,
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/.well-known/api-catalog",
      "destination": "/api/well-known-api-catalog"
    }
  ],
  "redirects": [
    {
      "source": "/swagger.html",
      "destination": "/swagger-credentialtype.html",
      "permanent": true
    },
    {
      "source": "/api/public/api-docs",
      "destination": "/api/public/credential-api-docs",
      "permanent": true
    }
  ],
  "functions": {
    "api/**/*.ts": {
      "memory": 256,
      "maxDuration": 10
    }
  }
}
